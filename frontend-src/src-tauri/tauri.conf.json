{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevHunt",
  "version": "1.0.0",
  "identifier": "com.devhunt.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1225",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DevHunt — AI Assistant & IDE",
        "width": 1440,
        "height": 920,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "url": "http://localhost:1225"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../backend/dist/devhunt_backend/**/*"
    ]
  }
}
